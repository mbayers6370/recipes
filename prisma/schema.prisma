generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  username     String  @unique
  passwordHash String  @map("password_hash")
  displayName  String? @map("display_name")
  avatarUrl    String? @map("avatar_url")
  bio          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipes         Recipe[]
  mealPlans       MealPlan[]
  groceryLists    GroceryList[]
  cookingSessions CookingSession[]
  refreshTokens   RefreshToken[]
  householdMember HouseholdMember?
  ownedHouseholds Household[]       @relation("HouseholdOwner")
  householdPlanItems HouseholdPlanItem[]
  householdIdeas HouseholdIdea[]
  householdIdeaVotes HouseholdIdeaVote[]

  @@map("users")
}

model Household {
  id        String @id @default(cuid())
  name      String
  ownerId   String @map("owner_id")
  owner     User   @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members HouseholdMember[]
  recipes Recipe[]
  plans   HouseholdPlan[]
  ideas   HouseholdIdea[]

  @@index([ownerId])
  @@map("households")
}

model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId      String    @unique @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([householdId, userId])
  @@index([householdId])
  @@map("household_members")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Recipe {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String?  @map("household_id")
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)
  title       String
  description String?
  imageUrl    String?  @map("image_url")
  sourceUrl   String?  @map("source_url")
  prepTime    Int?     @map("prep_time")
  cookTime    Int?     @map("cook_time")
  totalTime   Int?     @map("total_time")
  servings    Int?
  difficulty  String?
  cuisine     String?
  tags        String[]
  ingredients Json     @default("[]")
  steps       Json     @default("[]")
  nutrition   Json?
  notes       String?
  isFavorite  Boolean  @default(false) @map("is_favorite")
  isPublic    Boolean  @default(false) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mealPlanItems   MealPlanItem[]
  householdPlanItems HouseholdPlanItem[]
  householdIdeas  HouseholdIdea[]
  cookingSessions CookingSession[]

  @@index([userId])
  @@index([userId, isFavorite])
  @@index([householdId])
  @@map("recipes")
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @map("week_start")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items MealPlanItem[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("meal_plans")
}

model MealPlanItem {
  id         String   @id @default(cuid())
  mealPlanId String   @map("meal_plan_id")
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipeId   String?  @map("recipe_id")
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  dayOfWeek  Int      @map("day_of_week")
  mealType   String   @map("meal_type")
  note       String?
  servings   Int?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([mealPlanId])
  @@map("meal_plan_items")
}

model GroceryList {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items GroceryItem[]

  @@index([userId])
  @@map("grocery_lists")
}

model HouseholdPlan {
  id          String    @id @default(cuid())
  householdId String    @map("household_id")
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  weekStart   DateTime  @map("week_start")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items HouseholdPlanItem[]

  @@unique([householdId, weekStart])
  @@index([householdId])
  @@map("household_plans")
}

model HouseholdPlanItem {
  id              String        @id @default(cuid())
  householdPlanId String        @map("household_plan_id")
  householdPlan   HouseholdPlan @relation(fields: [householdPlanId], references: [id], onDelete: Cascade)
  recipeId        String?       @map("recipe_id")
  recipe          Recipe?       @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  createdByUserId String?       @map("created_by_user_id")
  createdByUser   User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  dayOfWeek       Int           @map("day_of_week")
  mealType        String        @map("meal_type")
  note            String?
  servings        Int?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([householdPlanId])
  @@index([createdByUserId])
  @@map("household_plan_items")
}

model HouseholdIdea {
  id               String              @id @default(cuid())
  householdId      String              @map("household_id")
  household        Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipeId         String              @map("recipe_id")
  recipe           Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  proposedByUserId String              @map("proposed_by_user_id")
  proposedByUser   User                @relation(fields: [proposedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  votes HouseholdIdeaVote[]

  @@unique([householdId, recipeId])
  @@index([householdId])
  @@index([proposedByUserId])
  @@map("household_ideas")
}

model HouseholdIdeaVote {
  id              String        @id @default(cuid())
  householdIdeaId String        @map("household_idea_id")
  householdIdea   HouseholdIdea @relation(fields: [householdIdeaId], references: [id], onDelete: Cascade)
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote            String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([householdIdeaId, userId])
  @@index([userId])
  @@map("household_idea_votes")
}

model GroceryItem {
  id            String      @id @default(cuid())
  groceryListId String      @map("grocery_list_id")
  groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
  name          String
  amount        String?
  unit          String?
  category      String?
  notes         String?
  isChecked     Boolean     @default(false) @map("is_checked")
  checkedAt     DateTime?   @map("checked_at")
  sortOrder     Int         @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([groceryListId])
  @@map("grocery_items")
}

model CookingSession {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId     String  @map("recipe_id")
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  currentStep  Int     @default(0) @map("current_step")
  servingScale Float   @default(1.0) @map("serving_scale")
  isCompleted  Boolean @default(false) @map("is_completed")

  startedAt DateTime @default(now()) @map("started_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, isCompleted])
  @@map("cooking_sessions")
}
